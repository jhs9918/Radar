{
  "manifest_version": 3,
  "name": "RFP Radar",
  "version": "1.0.0",
  "description": "Highlight any RFP text and analyze it instantly with RFP Radar.",
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RFP Radar"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
