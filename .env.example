# ============================================================
# RFP Radar — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or paste real API keys anywhere.
# ============================================================

# LLM Provider: "anthropic" (default) | "openai"
LLM_PROVIDER=anthropic

# Model name for the chosen provider.
# Anthropic examples: claude-haiku-4-5, claude-sonnet-4-5
# OpenAI examples:    gpt-4o-mini, gpt-4o
LLM_MODEL=claude-haiku-4-5

# Anthropic API Key — required when LLM_PROVIDER=anthropic
# Obtain at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key — required when LLM_PROVIDER=openai
# Obtain at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Free-tier limits ──────────────────────────────────────────────────────────
# Max analyses per IP per calendar month (default: 10)
FREE_MONTHLY_QUOTA=10

# Max characters in pasted/extracted text for free users (default: 12000)
FREE_CHAR_LIMIT=12000

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Sliding window duration in seconds (default: 600 = 10 min)
RATE_LIMIT_WINDOW_SEC=600

# Max requests per window per IP (default: 10)
RATE_LIMIT_MAX=10

# ── Access codes ──────────────────────────────────────────────────────────────
# Comma-separated codes that grant paid-tier access.
# Format: CODE[:YYYY-MM-DD|never]  — expiry is optional; bare code = never expires
# Example: ACCESS_CODES=BETA2024:2026-12-31,FRIEND50:never,LEGACYCODE
ACCESS_CODES=

# Immediately revoke specific codes (comma-separated).
# Example: REVOKED_CODES=OLDCODE,LEAKEDCODE
REVOKED_CODES=

# Optional per-code monthly use cap (0 = unlimited).
# Limits blast radius if a code is leaked or shared.
CODE_MONTHLY_MAX=0

# ── Dev / debugging ───────────────────────────────────────────────────────────
# Set to "true" ONLY in local development to include a raw LLM response snippet
# (first 200 chars) in parse-error logs. NEVER enable in production — user
# document content must not appear in logs.
LOG_LLM_RAW=false
